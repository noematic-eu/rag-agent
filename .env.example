# Path to your local f4kvs-ffi checkout (required for Docker build and make f4kvs).
# f4kvs-ffi is a separate dependency — not included in this repository.
# Remote: https://github.com/noematic-eu/f4kvs-ffi.git
F4KVS_ROOT=/Users/you/dev/rust/f4kvs-ffi

# Comma-separated browser origins allowed to call the API (live demo on Astro).
# RAG_CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
