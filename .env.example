# Path to your local f4kvs-v2 checkout (required for Docker build and make f4kvs).
# f4kvs-v2 is a separate dependency — not included in this repository.
# Remote: https://git.noematic.eu/f4kvs-org/f4kvs-v2.git
# Contact contact@noematic.eu for repository access.
F4KVS_ROOT=/Users/you/dev/rust/f4kvs-v2

# Comma-separated browser origins allowed to call the API (live demo on Astro).
# RAG_CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
