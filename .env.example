# Path to your local f4kvs-ffi checkout (only required for local builds: make f4kvs,
# make unikraft-prepare, or docker compose -f docker-compose.yml -f docker-compose.build.yml up -d --build).
# Pre-built images from ghcr.io/noematic-eu/rag-agent do not need this.
# Remote: https://github.com/noematic-eu/f4kvs-ffi.git
F4KVS_ROOT=/Users/you/dev/rust/f4kvs-ffi

# Comma-separated browser origins allowed to call the API (live demo on Astro).
# RAG_CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
