#!/bin/sh
set -eu

root=$(git rev-parse --show-toplevel)
cd "$root"

staged=$(
	git diff --cached --name-only --diff-filter=ACMD -- \
		agent/ client/ lexical/ model/ internal/ \
	| grep '\.go$' || true
)

if [ -z "$staged" ]; then
	exit 0
fi

unformatted=
for file in $staged; do
	if [ ! -f "$file" ]; then
		continue
	fi
	if [ -n "$(gofmt -l "$file")" ]; then
		unformatted="${unformatted}${file}
"
	fi
done
if [ -n "$unformatted" ]; then
	echo "gofmt check failed. Unformatted staged Go files:" >&2
	printf '%s' "$unformatted" | sed '/^$/d' | sed 's/^/  /' >&2
	echo "" >&2
	echo "Run: make fmt" >&2
	exit 1
fi

if ! command -v golangci-lint >/dev/null 2>&1; then
	echo "golangci-lint not found in PATH." >&2
	echo "Install: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2" >&2
	exit 1
fi

echo "Running golangci-lint..."
if ! golangci-lint run ./...; then
	echo "" >&2
	echo "golangci-lint failed. Fix the issues above before committing." >&2
	exit 1
fi
