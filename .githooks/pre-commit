#!/bin/sh
set -eu

root=$(git rev-parse --show-toplevel)
cd "$root"

staged=$(
	git diff --cached --name-only --diff-filter=ACM -- \
		agent/ client/ lexical/ model/ internal/ \
	| grep '\.go$' || true
)

if [ -z "$staged" ]; then
	exit 0
fi

unformatted=
for file in $staged; do
	if [ -n "$(gofmt -l "$file")" ]; then
		unformatted="${unformatted}${file}
"
	fi
done
if [ -n "$unformatted" ]; then
	echo "gofmt check failed. Unformatted staged Go files:" >&2
	printf '%s' "$unformatted" | sed '/^$/d' | sed 's/^/  /' >&2
	echo "" >&2
	echo "Run: make fmt" >&2
	exit 1
fi
